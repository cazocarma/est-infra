# =============================================================================
# EST — plantilla UNICA de entorno (compartida por back+front+infra).
# Copiar a .env (chmod 600) y completar los valores <changeme>.
# Fuente canonica: platform/docs/PLATFORM_INTEGRATION_SPEC.md §10.
#
# Este .env.example sirve tanto para prd (servidor remoto) como para dev local.
# En dev, docker-compose.override.yml pisa las URLs a localhost y relaja cookies.
# No hace falta un .env separado para local; cambia EST_ENV=dev y listo.
# =============================================================================

# ── Stack ────────────────────────────────────────────────────────────────────
EST_ENV=prd                          # prd | dev. Decide project name y etiquetas de imagen.
NODE_ENV=production                  # production (make up) | development (make up-dev)
LOG_LEVEL=info                       # trace | debug | info | warn | error
PORT=4000                            # puerto interno del back (convencion platform)

# ── SQL Server (DBEST en el SQL compartido 192.168.8.24) ────────────────────
DB_HOST=192.168.8.24
DB_PORT=1433
DB_NAME=DBEST
DB_USER=<changeme>
DB_PASSWORD=<changeme>
DB_ENCRYPT=true
DB_TRUST_SERVER_CERTIFICATE=true

# ── OIDC (Keycloak — realm ESTRealm en platform) ────────────────────────────
# Las URLs publicas quedan en prd; docker-compose.override.yml las pisa con
# localhost cuando se levanta con `make up-dev`.
OIDC_ISSUER_URL=http://192.168.18.18:8080/realms/ESTRealm
OIDC_DISCOVERY_URL=http://keycloak:8080/realms/ESTRealm/.well-known/openid-configuration
OIDC_CLIENT_ID=est-back
OIDC_CLIENT_SECRET=<changeme-hex-64>       # mismo valor que platform/.env:EST_BACK_CLIENT_SECRET
OIDC_REDIRECT_URI=http://192.168.18.18:82/api/v1/auth/callback
OIDC_POST_LOGOUT_REDIRECT_URI=http://192.168.18.18:82/login
OIDC_SCOPES=openid profile email
OIDC_REQUIRED_ROLE=est-user

# ── Sesion BFF (Redis — platform_cache, DB 4 reservada para EST) ────────────
# La URL debe llevar el password EN LITERAL. Copiar REDIS_PASSWORD desde
# platform/.env (no se puede interpolar via env_file). Ejemplo:
#   SESSION_REDIS_URL=redis://:AbCd1234...@redis:6379/4
SESSION_REDIS_URL=redis://:<REDIS_PASSWORD>@redis:6379/4
SESSION_COOKIE_NAME=est.sid
SESSION_COOKIE_SECRET=<changeme-hex-64>    # openssl rand -hex 32
SESSION_COOKIE_SECURE=true                 # true en prd (HTTPS). dev override lo pone false.
SESSION_COOKIE_SAMESITE=strict             # strict en prd. dev override lo pone lax.
SESSION_TTL_SECONDS=28800

# ── SAP ETL adapter (opcional — sync de maestros SAP) ───────────────────────
SAP_ETL_BASE_URL=
SAP_ETL_TOKEN=
SAP_ETL_TIMEOUT_MS=60000
