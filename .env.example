# ============================================================
# EST — Variables de configuracion (back + infra)
# ============================================================
#
# Estructura (alineada con platform/.env.example):
#   1. COMUN    — vars iguales en dev/prd o con defaults dev-friendly.
#   2. SECRETS  — completar con los valores reales (<changeme>).
#   3. SOLO PRD — referencia. Los overrides reales los aplica
#                 docker-compose.prd.yml cuando EST_ENV=prd. No hay que
#                 descomentar nada; los valores viven en el overlay.
#
# Seleccion de ambiente: EST_ENV=dev|prd. El Makefile lee este valor y
# aplica el overlay `docker-compose.${EST_ENV}.yml` automaticamente.
#
# En dev: NODE_ENV=development, OIDC URLs -> localhost, cookies relajadas,
# bind mounts + hot-reload.
#
# En prd: NODE_ENV=production, OIDC URLs -> IP LAN (192.168.18.18),
# cookies secure+strict, imagen runtime solo-lectura.
#
# Auth: BFF OIDC contra Keycloak. Ver platform/docs/AUTH_STANDARD.md §4 —
# DB 4 del platform_cache reservada para EST.
# ============================================================

# ============================================================
# 1. COMUN (dev y prd)
# ============================================================

# Ambiente: dev | prd. Default dev-friendly; el server tiene EST_ENV=prd.
EST_ENV=dev

# Puerto interno del back (el router de platform proxya :82 -> back:4000).
PORT=4000

# Log level. dev overlay lo pisa a "debug".
LOG_LEVEL=info

# ── SQL Server (DBEST en el SQL compartido 192.168.8.24) ─────
DB_HOST=192.168.8.24
DB_PORT=1433
DB_NAME=DBEST
DB_ENCRYPT=true
DB_TRUST_SERVER_CERTIFICATE=true

# ── OIDC (cliente `est-back` en realm ESTRealm) ──
# URLs publicas (ISSUER / REDIRECT / POST_LOGOUT) las pisa cada overlay
# con el host correspondiente (localhost en dev, IP LAN en prd).
OIDC_DISCOVERY_URL=http://keycloak:8080/realms/ESTRealm/.well-known/openid-configuration
OIDC_CLIENT_ID=est-back
OIDC_SCOPES=openid profile email
OIDC_REQUIRED_ROLE=est-user

# ── Sesion BFF (Redis — platform_cache, DB 4 reservada para EST) ──
SESSION_COOKIE_NAME=est.sid
SESSION_TTL_SECONDS=28800

# ── SAP ETL adapter (opcional — sync de maestros SAP) ──
# Dejar vacio para desactivar. Timeout igual en ambos ambientes.
SAP_ETL_BASE_URL=
SAP_ETL_TIMEOUT_MS=60000

# ============================================================
# 2. SECRETS (completar con valores reales)
# ============================================================

# SQL Server — usuario con permisos CRUD sobre DBEST.
DB_USER=<changeme>
DB_PASSWORD=<changeme>

# OIDC client secret. DEBE coincidir con platform/.env:EST_BACK_CLIENT_SECRET
# (keycloak-config-cli de platform inyecta el mismo valor al realm).
OIDC_CLIENT_SECRET=<changeme-hex-64>

# Redis session URL. El password va LITERAL (no se interpola via env_file).
# Copiar REDIS_PASSWORD desde platform/.env. Ejemplo:
#   SESSION_REDIS_URL=redis://:AbCd1234...@redis:6379/4
SESSION_REDIS_URL=redis://:<REDIS_PASSWORD>@redis:6379/4

# Secret para firmar la cookie de sesion. Generar: openssl rand -hex 32
SESSION_COOKIE_SECRET=<changeme-hex-64>

# Token de acceso al adapter greenvic-sap-etl (si SAP_ETL_BASE_URL esta seteado).
SAP_ETL_TOKEN=

# ============================================================
# 3. SOLO PRD (referencia — no editar aqui)
# ============================================================
#
# Los overrides de prd los aplica `docker-compose.prd.yml` al levantar el
# stack con EST_ENV=prd. NO hay que descomentar nada en este archivo.
#
# Para referencia, estos son los valores que el overlay prd inyecta:
#
#   NODE_ENV=production
#   LOG_LEVEL=info
#   OIDC_ISSUER_URL=http://192.168.18.18:8080/realms/ESTRealm
#   OIDC_REDIRECT_URI=http://192.168.18.18:82/api/v1/auth/callback
#   OIDC_POST_LOGOUT_REDIRECT_URI=http://192.168.18.18:82/login
#   SESSION_COOKIE_SECURE=true
#   SESSION_COOKIE_SAMESITE=strict
#
# Y los equivalentes dev los inyecta docker-compose.dev.yml con localhost
# y cookies relajadas.
